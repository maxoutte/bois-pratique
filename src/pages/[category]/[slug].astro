---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import { categoryMeta } from '../../data/site';

export async function getStaticPaths() {
  const entries = await getCollection('fr', ({ data }) => !data.draft);
  return entries.map((entry) => ({ params: { category: entry.data.category, slug: entry.id.split('/').pop() }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const categoryTitle = categoryMeta.fr[entry.data.category as keyof typeof categoryMeta.fr]?.title ?? entry.data.category;
---
<PostLayout lang="fr" title={entry.data.title} description={entry.data.description} categoryTitle={categoryTitle} pubDate={entry.data.pubDate} hero={entry.data.hero}>
  <Content />
</PostLayout>
