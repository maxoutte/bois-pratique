---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { categoryMeta, site } from '../../data/site';
import { entrySlug, getArticlesByCategory } from '../../utils/content';

export async function getStaticPaths() {
  return Object.keys(categoryMeta.fr).map((category) => ({ params: { category } }));
}

const { category } = Astro.params;
if (!category) throw new Error('Missing category');
const meta = categoryMeta.fr[category as keyof typeof categoryMeta.fr];
const articles = await getArticlesByCategory('fr', category);
---
<BaseLayout lang="fr" title={`${meta.title} — ${site.name}`} description={meta.description} image={`/images/categories/${category}.svg`}>
  <section class="container page-intro">
    <p class="eyebrow">Rubrique</p>
    <h1>{meta.title}</h1>
    <p class="lead">{meta.description}</p>
    <p>Des contenus pensés pour aider à mieux travailler, pas juste à remplir une catégorie. Ici, on trie ce qui sert vraiment de ce qui encombre.</p>
  </section>
  <section class="container section">
    <div class="grid-2">
      {articles.map((article) => (
        <ArticleCard href={`/${article.data.category}/${entrySlug(article.id)}/`} title={article.data.title} description={article.data.description} meta={article.data.contentType} image={article.data.hero} imageAlt={article.data.title} />
      ))}
    </div>
  </section>
</BaseLayout>
