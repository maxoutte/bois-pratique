---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { categoryMeta, site } from '../../data/site';
import { entrySlug, getFeaturedArticles } from '../../utils/content';

const featured = await getFeaturedArticles('en');
const categories = Object.entries(categoryMeta.en);
---
<BaseLayout lang="en" title={`${site.name} — ${site.tagline.en}`} description={site.description.en} image="/images/articles/og-default.svg">
  <section class="container hero">
    <div class="hero-panel hero-copy">
      <p class="eyebrow">Editorial woodworking</p>
      <h1>Practical woodworking, without fantasy-shop advice.</h1>
      <p class="lead">Bois Pratique publishes editorial guides on tools, workshop setup, materials and projects with one simple goal: help readers make cleaner decisions, cleaner cuts and cleaner builds.</p>
      <div class="cta-row">
        <a class="button primary" href="/en/buying-guides/">See buying guides</a>
        <a class="button secondary" href="/en/workshop/">Improve the shop</a>
      </div>
    </div>
    <div class="panel hero-visual">
      <img src="/images/brand/hero-bois-pratique.png" alt="Bois Pratique workshop scene" />
    </div>
  </section>

  <section class="container section">
    <h2>Start from the right premise</h2>
    <p class="lead">A believable beginner shop does not need to look impressive. It needs to let you mark accurately, cut cleanly, hold work properly and avoid foolish purchases. That is the editorial backbone of this site.</p>
  </section>



  <section class="container section">
    <h2>Recommended paths</h2>
    <div class="grid-3">
      <div class="panel">
        <p class="eyebrow">Starter shop</p>
        <h3><a href="/en/buying-guides/essential-woodworking-tools-beginners/">Build the base</a></h3>
        <p>Start with the right tools, in the right order, instead of turning the budget into a pile of random deals.</p>
      </div>
      <div class="panel">
        <p class="eyebrow">Cutting & accuracy</p>
        <h3><a href="/en/tools/best-circular-saw-beginners/">Cut more cleanly</a></h3>
        <p>Saw, blade and guidance: the trio that changes early project quality the most.</p>
      </div>
      <div class="panel">
        <p class="eyebrow">Living workshop</p>
        <h3><a href="/en/workshop/how-to-organize-small-shop/">Organize the space</a></h3>
        <p>Storage, bench, extraction and movement do more for a workshop than most beginner fantasies.</p>
      </div>
    </div>
  </section>

  <section class="container section">
    <h2>Core sections</h2>
    <div class="grid-3">
      {categories.map(([slug, meta]) => (
        <ArticleCard href={`/en/${slug}/`} title={meta.title} description={meta.description} meta="Section" image={`/images/categories/${slug}.png`} imageAlt={meta.title} />
      ))}
    </div>
  </section>

  <section class="container section">
    <h2>Priority articles</h2>
    <p class="lead">The pages most likely to improve workshop decisions early and remove the most common beginner mistakes.</p>
    <div class="grid-2">
      {featured.map((article) => (
        <ArticleCard href={`/en/${article.data.category}/${entrySlug(article.id)}/`} title={article.data.title} description={article.data.description} meta={article.data.contentType} image={article.data.hero} imageAlt={article.data.title} />
      ))}
    </div>
  </section>
</BaseLayout>
